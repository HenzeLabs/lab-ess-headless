{
  "name": "lab-ess-headless",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "check:safe": "npm run typecheck && npm run lint && npm run build && playwright test tests/homepage.spec.ts tests/collections.spec.ts tests/products.spec.ts tests/cart.spec.ts tests/checkout.spec.ts",
    "analyze": "cross-env ANALYZE=true next build",
    "lh": "lhci autorun --config=./lighthouse.config.js",
    "clean:shopify": "tools/shopify-cleanup/bin/index.sh",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:homepage": "playwright test tests/homepage.spec.ts",
    "test:collections": "playwright test tests/collections.spec.ts",
    "test:products": "playwright test tests/products.spec.ts",
    "test:cart": "playwright test tests/cart.spec.ts",
    "test:checkout": "playwright test tests/checkout.spec.ts tests/checkout-flow.spec.ts",
    "test:orders": "playwright test tests/orders.spec.ts",
    "test:auth": "playwright test tests/auth-comprehensive.spec.ts tests/account.spec.ts",
    "test:auth:headed": "playwright test tests/auth-comprehensive.spec.ts tests/account.spec.ts --headed",
    "test:core": "playwright test tests/homepage.spec.ts tests/collections.spec.ts tests/products.spec.ts tests/cart.spec.ts tests/checkout.spec.ts tests/checkout-flow.spec.ts",
    "test:full": "playwright test tests/homepage.spec.ts tests/collections.spec.ts tests/products.spec.ts tests/cart.spec.ts tests/checkout.spec.ts tests/checkout-flow.spec.ts tests/auth-comprehensive.spec.ts tests/account.spec.ts tests/orders.spec.ts",
    "test:ci": "npm run test:full",
    "test:report": "playwright show-report",
    "test:install": "playwright install",
    "fetch-product-handle": "node fetch-product-handle.mjs"
  },
  "dependencies": {
    "@google-analytics/data": "^5.2.0",
    "@heroicons/react": "^2.2.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.3",
    "@sentry/nextjs": "^8.47.0",
    "@tanstack/react-query": "^5.90.1",
    "@types/cookie": "^0.6.0",
    "@upstash/redis": "^1.35.4",
    "class-variance-authority": "^0.7.1",
    "cookie": "^1.0.2",
    "critters": "^0.0.23",
    "dotenv": "^17.2.2",
    "framer-motion": "^12.23.18",
    "jose": "^6.1.0",
    "lucide-react": "^0.544.0",
    "next": "^15.5.2",
    "next-pwa": "^5.6.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "tailwindcss": "^3.4.3",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@jest/globals": "^30.1.2",
    "@next/bundle-analyzer": "^15.5.4",
    "@playwright/test": "^1.55.0",
    "@tailwindcss/typography": "^0.5.16",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.3.1",
    "@types/react": "^19",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.57.0",
    "eslint-config-next": "^15.5.3",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "jest-canvas-mock": "^2.5.2",
    "lhci": "^4.1.1",
    "postcss": "^8.5.6",
    "tailwindcss-animate": "^1.0.7",
    "ts-jest": "^29.4.4",
    "typescript": "^5"
  }
}
