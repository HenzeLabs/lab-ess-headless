## Required for Shopify Storefront API
# Your myshopify domain (no protocol), e.g. my-store.myshopify.com
SHOPIFY_STORE_DOMAIN=
# Primary token used by the app
SHOPIFY_STOREFRONT_ACCESS_TOKEN=
# Optional legacy name accepted by the client (fallback)
# SHOPIFY_STOREFRONT_API_TOKEN=
# API version (defaults to 2025-01 if unset)
# SHOPIFY_API_VERSION=2025-01

## Public site URL (no trailing slash), used for SEO/sitemaps
NEXT_PUBLIC_SITE_URL=

## Optional: enable bundle analyzer during build
# ANALYZE=true

## Security Configuration
# Redis Rate Limiting (Upstash Redis)
UPSTASH_REDIS_REST_URL=https://your-redis-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# Alternative: ioredis connection (if using traditional Redis)
# REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=your-redis-password
# REDIS_DB=0

## Analytics Configuration (GDPR Compliant)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_CLARITY_PROJECT_ID=your-clarity-id

## Admin Security
ADMIN_TOKEN=your-secure-admin-token

## Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_MAX_REQUESTS=5
RATE_LIMIT_CART_MAX_REQUESTS=30
RATE_LIMIT_ADMIN_MAX_REQUESTS=10

## GDPR Compliance
COOKIE_CONSENT_VERSION=1
PRIVACY_POLICY_URL=/privacy
TERMS_OF_SERVICE_URL=/terms
